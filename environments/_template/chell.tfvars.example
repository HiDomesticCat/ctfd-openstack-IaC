# environments/lab50/chell.tfvars.example
# 複製為 chell.tfvars 後填入實際值

openstack_cloud = "ctfd"

# ── Shared Network 模式 ──────────────────────────────────────
use_shared_network  = true
shared_network_name = "shared-public3"

# ── Network MTU ──────────────────────────────────────────────
# 此叢集 path MTU 實測 ~928，請設 900。default=1450 是 textbook VXLAN 值，
# 會讓 HTTPS 大封包 RST。對齊 ctfd/ 與 gamma4-lab-infra。
network_mtu = 900

# ── Instance ─────────────────────────────────────────────────
image_id         = "<FROM_PLATFORM_OUTPUT>"
master_flavor    = "basic-2c4g"
worker_flavor    = "basic-2c4g"
worker_count     = 2
floating_ip_pool = "public3"

# ── SSH ──────────────────────────────────────────────────────
keypair_name    = "chell-key"
public_key_path = "~/.ssh/id_rsa.pub"

# ── k3s ──────────────────────────────────────────────────────
k3s_token = "<GENERATE_WITH: openssl rand -hex 32>"

# ── Registry（k3s 節點 pull challenge image 用）─────────────
# CTFd host 的內網 IP（與 k3s 節點同子網）
# 空字串=不設定 registries.yaml（k3s 只能用公開 image）
# registry_ip = "192.168.234.217"
