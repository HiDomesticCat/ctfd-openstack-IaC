# OpenStack 認證設定
# 複製為 credentials.auto.pkrvars.hcl 後填入實際值
# ⚠️ 此檔案含敏感資訊，已被 .gitignore 排除

openstack_auth_url     = "http://192.168.15.200:5000/v3"
openstack_username     = "ctfd-deployer"
openstack_password     = "CHANGE_ME"
openstack_project_name = "ctfd"
openstack_region       = "RegionOne"
openstack_domain       = "Default"

# 從 ctfd layer 取得（tofu output -raw network_id）
network_id        = "CHANGE_ME"

# 從 platform layer 取得（tofu output -json image_ids）
source_image_id   = "CHANGE_ME"
