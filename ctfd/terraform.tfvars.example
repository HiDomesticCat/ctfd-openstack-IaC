# ctfd-openstack/terraform.tfvars.example
# 複製此檔案為 terraform.tfvars 並填入實際值
# 重要：terraform.tfvars 已加入 .gitignore，請勿手動提交

# ── Provider ───────────────────────────────────────────────
# clouds.yaml 中的 cloud entry 名稱（ctfd-deployer 帳號）
openstack_cloud = "ctfd"

# ── 從 platform 取得的值 ────────────────────────────────────
# 執行 cd ../platform && tofu output 後複製以下兩個值

# platform output: module.external_network.network_id
external_network_id = "PASTE_FROM_PLATFORM_OUTPUT"

# platform output: module.images.image_ids["ubuntu"]  (或使用 image 名稱查 OpenStack)
image_id = "PASTE_FROM_PLATFORM_OUTPUT"

# ── SSH ────────────────────────────────────────────────────
keypair_name    = "ctfd-key"
public_key_path = "/root/.ssh/id_rsa.pub"

# 建議限制為管理 IP，例如 "203.0.113.0/24"
# ssh_allowed_cidr = "0.0.0.0/0"

# ── Network ────────────────────────────────────────────────
internal_subnet_cidr = "192.168.100.0/24"

# 此叢集 path MTU 實測 ~928，請設 900（28 bytes 餘裕）。default=1450
# 是 textbook VXLAN 值，會讓 HTTPS 大封包 RST。對齊 chell/ 與 gamma4-lab-infra。
network_mtu = 900

# ── Instance ───────────────────────────────────────────────
flavor_name   = "general.medium"
instance_name = "ctfd-server"

# Floating IP 所在的外部網路名稱（與 platform network_name 一致）
floating_ip_pool = "public"

# CTFd 應用程式 Port
ctfd_port = 8000

# ── Phase 3 α-exposure (gamma4 research VM 整合) ─────────────
# Set the four below + tofu apply when you want gamma4 to talk to
# chall-manager + registry through cm-proxy on challenge-net.
#
# expose_cm_proxy_to_challenge_net = true
# cm_proxy_allowed_cidr            = "<gamma4 challenge-net IP>/32"
# cm_proxy_chall_manager_port      = 8443
# cm_proxy_registry_port           = 5443
# cm_proxy_fixed_ip                = "<CTFd VM challenge-net IP, e.g. 192.168.78.162>"

# ── K3s direct registry ingress on challenge-net ────────────
# K3s workers have no route to the CTFd internal subnet
# (192.168.100.0/24), so the k8s-pod scenario rewrites image refs to
# <ctfd_challenge_net_ip>:5000 and pulls over challenge-net. Open
# 5000/tcp on the CTFd VM's secgroup to the challenge-net /24:
#
# registry_allowed_cidr = "192.168.78.0/24"
#
# Pair this with the worker side:
#   /etc/rancher/k3s/registries.yaml on each worker must mirror
#   "<ctfd_challenge_net_ip>:5000" -> "http://<ctfd_challenge_net_ip>:5000"
#   then `sudo systemctl restart k3s-agent` to reload containerd.
